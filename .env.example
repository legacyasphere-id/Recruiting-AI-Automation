# Recruiting AI Automation — environment template
# Copy to .env and fill in real values. NEVER commit .env.
# Full strategy (what lives here vs. the n8n credential store): docs/SECRETS.md

# ── Claude API ────────────────────────────────────────────────
# Classification (Phase II), summaries and draft replies (Phase III)
ANTHROPIC_API_KEY=
# Model for the messenger classifier (defaults to claude-opus-4-8)
CLAUDE_MODEL=claude-opus-4-8

# ── Messenger service (Phase II) ──────────────────────────────
CLASSIFIER_PORT=8787
CLASSIFIER_HOST=0.0.0.0
# Base URL n8n uses to reach the service, e.g. http://localhost:8787
CLASSIFIER_URL=

# ── Supabase (CRM / Memory, Phase IV) ─────────────────────────
SUPABASE_URL=
# Server-side only — full access, never expose to a browser
SUPABASE_SERVICE_ROLE_KEY=
# Safe for client-side use with row-level security enabled
SUPABASE_ANON_KEY=

# ── Slack (Watcher digests + review notifications, Phase V/VII)
SLACK_WEBHOOK_URL=

# ── Calendly (Clockkeeper, Phase VI) ──────────────────────────
CALENDLY_API_TOKEN=

# ── n8n host ──────────────────────────────────────────────────
# Encrypts n8n's credential store (Gmail OAuth lives there, not here).
# Back this up in a password manager — losing it orphans all n8n credentials.
N8N_ENCRYPTION_KEY=

# ── Runtime ───────────────────────────────────────────────────
# Business-day / follow-up logic depends on a consistent timezone
TZ=Asia/Jakarta
